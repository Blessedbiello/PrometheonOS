    "dotenv": "^17.4.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
