{
  "name": "@prometheon/ai-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PrometheonOS AI strategist: pluggable LLM provider; tip/timing/retry decisions over NATS.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
