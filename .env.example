# ── PrometheonOS configuration (copy to .env; .env is gitignored) ─────────────

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Dev/testnet for development + fault injection; mainnet for the proof run.
RPC_URL=https://api.testnet.solana.com
RPC_URL_MAINNET=
# WebSocket RPC (optional, for cross-check)
RPC_WS_URL=

# ── Yellowstone gRPC (Geyser / Dragon's Mouth) — SolInfra credits ─────────────
YELLOWSTONE_ENDPOINT=
YELLOWSTONE_X_TOKEN=
# processed | confirmed | finalized  (subscribe low, track progression client-side)
YELLOWSTONE_COMMITMENT=confirmed

# ── Jito Block Engine ─────────────────────────────────────────────────────────
# Pick the region closest to where this runs.
#   mainnet: https://<region>.mainnet.block-engine.jito.wtf  (ny, amsterdam, frankfurt, london, slc, singapore, tokyo)
#   testnet: https://testnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://testnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL_MAINNET=https://ny.mainnet.block-engine.jito.wtf
# Tip floor REST (mainnet data): https://bundles.jito.wtf/api/v1/bundles/tip_floor
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
# Optional UUID for higher rate limits (sent as x-jito-auth header / ?uuid=)
JITO_AUTH_UUID=

# ── Wallet ────────────────────────────────────────────────────────────────────
# Path to a funded keypair file (testnet + a small mainnet wallet). NEVER commit.
WALLET_KEYPAIR_PATH=./wallets/payer.testnet.json
WALLET_KEYPAIR_PATH_MAINNET=./wallets/payer.mainnet.json

# ── AI agent (pluggable provider) ─────────────────────────────────────────────
# anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Point the OpenAI provider at ANY OpenAI-compatible endpoint instead of api.openai.com:
# a Nosana inference endpoint (decentralized GPU on Solana), vLLM/TGI, Together, Groq, etc.
# Set LLM_PROVIDER=openai, OPENAI_BASE_URL=<endpoint>/v1, OPENAI_API_KEY=<issued key>,
# OPENAI_MODEL=<served model id>. Leave empty for OpenAI itself.
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Infra (docker-compose) ────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
DATABASE_URL=postgres://prometheon:prometheon@localhost:55432/prometheon
PROMETHEUS_METRICS_ADDR=0.0.0.0:9100

# ── Engine tuning ─────────────────────────────────────────────────────────────
# Network: testnet | mainnet — selects which RPC/Jito/wallet set is active.
NETWORK=testnet
INGEST_CHANNEL_CAPACITY=8192
LOG_LEVEL=info
